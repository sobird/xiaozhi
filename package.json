{
  "name": "@sobird/xiaozhi",
  "version": "1.2.5",
  "description": "Run your XiaoZhi AI on the terminal",
  "keywords": [
    "ai",
    "terminal",
    "typescript",
    "xiaozhi"
  ],
  "homepage": "https://github.com/sobird/xiaozhi",
  "bugs": {
    "url": "https://github.com/sobird/xiaozhi/issues"
  },
  "license": "MIT",
  "author": "sobird",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sobird/xiaozhi.git"
  },
  "bin": {
    "xiaozhi": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun src/cli.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "echo \"postinstall\"",
    "prepare": "husky",
    "prepublishOnly": "bun run build && bun scripts/prepublish.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "commander": "^13.1.0",
    "mqtt": "^5.10.3",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "rc": "^1.2.8",
    "string-width": "^7.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@types/bun": "1.3.11",
    "@types/prompts": "^2.4.9",
    "@types/rc": "^1.2.4",
    "@types/ws": "^8.5.14",
    "@types/xml2js": "^0.4.14",
    "aedes": "^0.51.3",
    "husky": "^9.1.7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.2",
    "ws": "^8.18.0"
  }
}
